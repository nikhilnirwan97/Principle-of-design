# ─── Supabase Credentials ───────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key-here

# Storage bucket name (create this in Supabase → Storage)
SUPABASE_BUCKET=yamuna-reports

# Flask secret key (keep random)
FLASK_SECRET=change-me-to-a-random-string
